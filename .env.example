# ─────────────────────────────────────────────────────────────────────────────
# Teach AI for India — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. All secrets live in Vercel env vars in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key are safe to expose to the browser (protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key bypasses RLS — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Used by server actions / edge functions for admin operations (invites, seeding).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
EMAIL_FROM="Teach AI for India <noreply@teachaiforindia.org>"

# ── App ─────────────────────────────────────────────────────────────────────
# Public base URL — used for invite links and email CTAs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
